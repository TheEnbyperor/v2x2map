<?xml version="1.0" encoding="utf-8"?>
<!-- One row per station (MAC / stationId).
     Columns: type-icon | ID + summary | last-seen | distance | lock | chevron -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="4dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Message-type icon (car / traffic light / hazard / …) -->
    <ImageView
        android:id="@+id/stationIcon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="6dp"
        android:contentDescription=""/>

    <!-- Station ID + summary line (takes remaining width) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/stationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/stationSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:alpha="0.7"
            android:singleLine="true"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Last-seen time -->
    <TextView
        android:id="@+id/stationTime"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="end"
        android:alpha="0.75"/>

    <!-- Distance to user -->
    <TextView
        android:id="@+id/stationDist"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textSize="10sp"
        android:gravity="end"
        android:alpha="0.75"/>

    <!-- Lock: closed (green) = secured, open (red) = unsecured, gone = unknown -->
    <ImageView
        android:id="@+id/stationLock"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="4dp"
        android:contentDescription="secured"/>

    <!-- Expand / collapse chevron -->
    <ImageView
        android:id="@+id/stationChevron"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:padding="1dp"
        android:layout_marginStart="2dp"
        android:contentDescription="@string/toggle_log"
        app:srcCompat="@drawable/ic_expand_more"/>

</LinearLayout>
